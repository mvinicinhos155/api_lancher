{
    "compilerOptions": { 
        "target": "es2020",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,  

        "forceConsistentCasingInFileNames": true,
        "types": ["node"]
    },
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "exclude": ["node_modules"]

}